@startuml
!include ../_style.puml

title Storage-Service Filesystem Layout

skinparam nodesep 40
skinparam ranksep 40
skinparam ArrowFontSize 11
skinparam roundCorner 8

skinparam node<<file system>> {
  BackgroundColor #F0F0F0
  BorderColor #666666
}
skinparam node<<execution environment>> {
  BackgroundColor #FDECEA
  BorderColor #B0413E
}
skinparam artifact {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}

node "/storage/\nroot of all registered users" as StorageRoot <<file system>> {

  node "user7k2m9x/\n{owner = root:root}\n{home = none, shell = none}" as U1 <<execution environment>> {
    artifact "data/\n{owner = user7k2m9x:user7k2m9x}\n{writable = true}" as D1
  }

  node "user3f9a1c/\n{owner = root:root}\n{home = none, shell = none}" as U2 <<execution environment>> {
    artifact "data/\n{owner = user3f9a1c:user3f9a1c}\n{writable = true}" as D2
  }
}

note bottom of StorageRoot
  Pattern repeats per registered user "user<xxxxxx>" (ST-F-06). Each execution
  environment is an isolated chroot the user can never leave (ST-F-05, ST-F-07);
  data/ is the only writable path, holding Restic's client-side-encrypted backups (ST-F-02, ST-F-08).
end note

@enduml
