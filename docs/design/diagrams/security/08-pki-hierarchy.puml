@startuml
!include ../_style.puml

title PKI Hierarchy

skinparam nodesep 30
skinparam ranksep 50
skinparam ArrowFontSize 11

' publicCA: pale neutral/ice tone — signals "external to the system" (Let's Encrypt).
skinparam component<<publicCA>> {
  BackgroundColor #DDE6ED/#C3D2DC
  BorderColor #5A6B78
  FontColor #14202B
}
' privateCA: teal family, same as <<infra>> but a distinct lighter variant —
' the private CA is support infrastructure, conceptually close to <<infra>>.
skinparam component<<privateCA>> {
  BackgroundColor #A9CDD6/#7FB0BC
  BorderColor #3D6570
  FontColor #0A1B22
}
' <<service>> intentionally NOT redefined here: inherited as-is from
' _style.puml (navy blue family). Do not add a local block for it — see
' _style.puml comment on skinparam merging per-selector, not per-block.

component "**Let's Encrypt**" as LetsEncrypt <<publicCA>>
component "**Certificate-Authority**\n[smallstep/certificates]" as PrivateCA <<privateCA>>

package "Core request path" {
  together {
    component "**Entry-Hub**" as EntryHub <<service>>
    component "**Security-Switch**" as SecuritySwitch <<service>>
    component "**Database-Vault**" as DatabaseVault <<service>>
    component "**Storage-Service**" as StorageService <<service>>
    component "**Network-Manager**" as NetworkManager <<service>>
  }

  EntryHub -[hidden]right- SecuritySwitch
  SecuritySwitch -[hidden]right- DatabaseVault
  DatabaseVault -[hidden]right- StorageService
  StorageService -[hidden]right- NetworkManager
}

package "Monitoring pipeline" {
  component "**Mosquitto**\n[MQTT-Broker]" as MqttBroker <<service>>
  component "**Metrics-Collector**" as MetricsCollector <<service>>
  component "**Metrics-Visualizer**\n[Grafana]" as MetricsVisualizer <<service>>

  MqttBroker -[hidden]right- MetricsCollector
  MetricsCollector -[hidden]right- MetricsVisualizer
}

LetsEncrypt ..> EntryHub

PrivateCA ..> EntryHub
PrivateCA ..> SecuritySwitch
PrivateCA ..> DatabaseVault
PrivateCA ..> StorageService
PrivateCA ..> NetworkManager
PrivateCA ..> MqttBroker
PrivateCA ..> MetricsCollector
PrivateCA ..> MetricsVisualizer
PrivateCA ..> PrivateCA : self-signed

legend
  every dashed arrow is a <<signs>> relationship
  (certificate issuance)
end legend

@enduml
