@startuml
!include ../_style.puml

title Use Case Diagram

left to right direction
skinparam linetype ortho

actor User
actor Admin

rectangle "RAM-USB" {
  together {
    usecase "UC-01\nRegister" as UC1
    usecase "UC-04\nRestore a file" as UC4
    usecase "UC-03\nBack up a file" as UC3
    usecase "UC-05\nConsult operational metrics" as UC5
  }
  usecase "UC-02\nLogin" as UC2
}

User -- UC1
User -- UC3
User -- UC4
User -- UC2
Admin -- UC5

UC3 ..> UC2 : <<include>>
UC4 ..> UC2 : <<include>>

@enduml
