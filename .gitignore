# Generated dev-only TLS key material (third-party/entry-hub/generate-dev-cert.sh,
# third-party/network-manager/headscale/dev-tls/README.txt's openssl command) -
# real key bytes, regenerated on demand, never committed (unlike the
# zero-entropy *.dev-only.txt placeholder files elsewhere under third-party/).
# The headscale key was committed by mistake on 2026-07-16 (found via
# gitleaks 2026-07-20) - inconsistent with this same rule already applied
# to entry-hub's equivalent; tracking removed via `git rm --cached`, see
# git-agent's advisory for the exact commit.
third-party/entry-hub/config/*.dev-only.*
third-party/network-manager/headscale/dev-tls/*.dev-only.pem

# third-party/mosquitto/generate-dev-certs.sh's output: one dev-only MQTT
# CA plus a broker cert and one client cert per publishing/subscribing
# identity - real key bytes, regenerated on demand, never committed, same
# convention as the entries above.
third-party/mosquitto/certs/*.dev-only.*
third-party/mosquitto/certs/*.srl

# Real dev-only master key/pepper/CA bootstrap tokens generated while
# manually verifying the full stack against a real running Certificate-
# Authority (2026-07-20 real-CA end-to-end test) - never committed.
deployments/.env.realca-test
